---
layout: null
permalink: /signal/feed.xml
---
{% assign issues = site.pages | where: "layout", "issue" | where_exp: "p", "p.url contains '/signal/'" | sort: "date" | reverse -%}
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Signal · Golden Data</title>
  <subtitle>Weekly notes on AI features that actually ship in B2B SaaS — sales ops, ad tech, analytics, BI.</subtitle>
  <link href="{{ '/signal/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/signal/' | absolute_url }}" rel="alternate" type="text/html" />
  <id>{{ '/signal/' | absolute_url }}</id>
  {% if issues.first -%}
  <updated>{{ issues.first.date | date_to_xmlschema }}</updated>
  {%- else -%}
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  {%- endif %}
  <author>
    <name>Paul Brown</name>
    <email>thegoldendata@gmail.com</email>
    <uri>{{ '/' | absolute_url }}</uri>
  </author>
  <rights>© {{ site.time | date: '%Y' }} Golden Data LLC</rights>
  {% for issue in issues -%}
  <entry>
    <title>{{ issue.title | xml_escape }}</title>
    <link href="{{ issue.url | absolute_url }}" rel="alternate" type="text/html" />
    <id>{{ issue.url | absolute_url }}</id>
    <updated>{{ issue.date | date_to_xmlschema }}</updated>
    <published>{{ issue.date | date_to_xmlschema }}</published>
    <author><name>Paul Brown</name></author>
    <category term="Signal" />
    {%- if issue.issue_number %}
    <category term="Issue #{{ issue.issue_number }}" />
    {%- endif %}
    {%- if issue.description %}
    <summary>{{ issue.description | xml_escape }}</summary>
    {%- endif %}
    <content type="html">{{ issue.content | xml_escape }}</content>
  </entry>
  {% endfor -%}
</feed>
